<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Dashboard - RastreaCom</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/auth.css">
</head>

<body class="auth-page">
    <header class="nav">
        <div class="container nav-inner">
            <a class="brand" href="/">
                <span class="logo" aria-hidden="true"></span>
                <span>RastreaCom</span>
            </a>

            <div class="nav-links">
                <a href="/user/dashboard">Dashboard</a>
                <a href="/user/analyze">Analizar</a>
  
            </div>

            <form method="POST" action="/logout" style="margin:0;">
                <button class="btn ghost" type="submit">Salir</button>
            </form>
        </div>
    </header>

    <main class="auth-main">
        <section class="hero" style="padding: 34px 0 10px;">
            <div class="parallax" aria-hidden="true">
                <div class="stars" data-speed="0.18"></div>
                <div class="blob one" data-speed="0.35"></div>
                <div class="blob two" data-speed="0.55"></div>
            </div>

            <div class="container">
                <div
                    style="display:flex; align-items:flex-end; justify-content:space-between; gap:14px; flex-wrap:wrap;">
                    <div>
                        <div class="badge">Panel</div>
                        <h1 style="margin:10px 0 6px; font-size: 28px; letter-spacing: -.3px;">Bienvenido, <%=
                                user.nombre %>
                        </h1>
                        <p class="small" style="margin-top:0;">Aquí tienes un resumen rápido del sistema.</p>
                        <% if (typeof error !=="undefined" && error) { %>
                            <div class="auth-alert" style="margin-top:10px;">
                                <%= error %>
                            </div>
                            <% } %>
                    </div>

                    <div style="display:flex; gap:10px; flex-wrap:wrap;">
                        <a class="btn primary" href="/user/analyze">Analizar nueva URL →</a>
                        <a class="btn ghost" href="/user/profile">Ver perfil</a>
                    </div>
                </div>

                <div style="height: 18px;"></div>

                <div class="row g-3">
                    <div class="col-12 col-md-4">
                        <div class="card panel" style="min-height: 140px;">
                            <div class="panel-title">
                                <strong>Usuarios</strong>
                                <span class="badge">Total</span>
                            </div>
                            <div style="font-size: 34px; font-weight: 800; line-height: 1; margin-top: 6px;">
                                <%= (stats && typeof stats.usersCount !=="undefined" ) ? stats.usersCount : 0 %>
                            </div>
                            <p class="small" style="margin-top: 8px;">Cuentas registradas en el sistema.</p>
                        </div>
                    </div>

                    <div class="col-12 col-md-4">
                        <div class="card panel" style="min-height: 140px;">
                            <div class="panel-title">
                                <strong>Sitios analizados</strong>
                                <span class="badge">Total</span>
                            </div>
                            <div style="font-size: 34px; font-weight: 800; line-height: 1; margin-top: 6px;">
                                <%= (stats && typeof stats.sitesCount !=="undefined" ) ? stats.sitesCount : 0 %>
                            </div>
                            <p class="small" style="margin-top: 8px;">Webs guardadas en Mongo (caché/histórico).</p>
                        </div>
                    </div>

                    <div class="col-12 col-md-4">
                        <div class="card panel" style="min-height: 140px;">
                            <div class="panel-title">
                                <strong>Tu sesión</strong>
                                <span class="badge">Activa</span>
                            </div>
                            <p class="small" style="margin-top: 4px;">
                                <b>Usuario:</b>
                                <%= user.nombre %><br />
                                    <b>Email:</b>
                                    <%= user.email %>
                            </p>
                            <div style="margin-top: 8px;">
                                <a class="btn ghost" href="/user/analyze" style="width:100%;">Ir al analizador</a>
                            </div>
                        </div>
                    </div>
                </div>

                <div style="height: 18px;"></div>

                <div class="card panel">
                    <div class="panel-title">
                        <strong>Acciones rápidas</strong>
                        <span class="badge">Atajos</span>
                    </div>

                    <div style="display:flex; gap:10px; flex-wrap:wrap;">
                        <a class="btn primary" href="/user/analyze">+ Analizar URL</a>
                        <a class="btn ghost" href="/user/profile">Editar perfil</a>
                    </div>

                    <p class="small" style="margin-top: 10px;">
                        Tip: si analizas la misma web varias veces, el sistema puede servir resultados desde caché
                        (Mongo) para ir más rápido.
                    </p>
                </div>
            </div>
        </section>

        <footer class="auth-footer text-center" style="margin-top: 22px;">
            <div class="container footer-inner">
                <span>© <span id="year"></span> RastreaCom</span>
                <span>Dashboard · Node + Express · Mongo</span>
            </div>
        </footer>
    </main>

    <script>
        document.getElementById("year").textContent = new Date().getFullYear();

        const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        if (!reduceMotion) {
            const layers = document.querySelectorAll("[data-speed]");
            const onScroll = () => {
                const y = window.scrollY || 0;
                layers.forEach(el => {
                    const speed = parseFloat(el.getAttribute("data-speed")) || 0.2;
                    el.style.transform = `translate3d(0, ${y * speed}px, 0)`;
                });
            };
            onScroll();
            window.addEventListener("scroll", onScroll, { passive: true });
        }
    </script>
</body>

</html>