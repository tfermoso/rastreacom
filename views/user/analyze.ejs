<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Analizar URL - RastreaCom</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/auth.css">

  <style>
    /* Layout */
    .layout{
      display:grid;
      grid-template-columns: 1fr 360px;
      gap:14px;
      align-items:start;
    }
    @media (max-width: 980px){ .layout{ grid-template-columns: 1fr; } }

    /* Estado / spinner */
    .status{ display:flex; align-items:center; gap:10px; min-height:24px; margin-top:8px; }
    .spinner{
      width:18px; height:18px;
      border:3px solid rgba(255,255,255,.18);
      border-top-color: rgba(255,255,255,.75);
      border-radius:50%;
      animation: spin .8s linear infinite;
      display:none;
    }
    .loading .spinner{ display:inline-block; }
    .loading .status-text{ opacity:.85; }
    @keyframes spin{ to { transform: rotate(360deg); } }

    /* Resultado */
    .kv{
      display:grid;
      grid-template-columns: 130px 1fr;
      gap:8px 12px;
      margin-top:10px;
    }
    .kv .k{ color: rgba(255,255,255,.68); font-size:12px; }
    .kv .v{ color: rgba(255,255,255,.92); font-size:13px; word-break: break-word; }

    .pill{
      display:inline-flex;
      align-items:center;
      padding:6px 10px;
      border-radius:999px;
      border: 1px solid rgba(255,255,255,.12);
      background: rgba(255,255,255,.05);
      color: rgba(255,255,255,.85);
      font-size:12px;
      margin:4px 6px 0 0;
      text-decoration:none;
    }
    .pill:hover{ background: rgba(255,255,255,.07); }
    .muted{ color: rgba(255,255,255,.68); }

    .error-box{
      border: 1px solid rgba(255,120,120,.25);
      background: rgba(255,80,80,.08);
      color: rgba(255,220,220,.95);
      padding:10px 12px;
      border-radius:14px;
      font-size:13px;
      margin-top:10px;
      white-space: pre-wrap;
    }

    /* Recientes */
    .recent-item{
      display:flex;
      flex-direction:column;
      gap:2px;
      padding:10px 10px;
      border-radius:14px;
      border:1px solid rgba(255,255,255,.10);
      background: rgba(255,255,255,.04);
      text-decoration:none;
    }
    .recent-item:hover{
      background: rgba(255,255,255,.06);
      border-color: rgba(255,255,255,.16);
    }
    .recent-url{ color: rgba(255,255,255,.92); font-size:13px; word-break: break-word; }
    .recent-meta{ font-size:12px; color: rgba(255,255,255,.62); display:flex; gap:10px; flex-wrap:wrap; }

    /* Chat widget */
    .rc-chat-launcher{
      position: fixed;
      right: 18px;
      bottom: 18px;
      z-index: 9999;
      border-radius: 999px;
      padding: 10px 14px;
      border: 1px solid rgba(255,255,255,.15);
      background: rgba(0,0,0,.55);
      backdrop-filter: blur(10px);
      color: rgba(255,255,255,.92);
      cursor: pointer;
      display:flex;
      gap:10px;
      align-items:center;
      user-select:none;
    }
    .rc-chat{
      position: fixed;
      right: 18px;
      bottom: 70px;
      width: min(420px, calc(100vw - 36px));
      height: 520px;
      z-index: 9999;
      border-radius: 18px;
      border: 1px solid rgba(255,255,255,.15);
      background: rgba(0,0,0,.55);
      backdrop-filter: blur(10px);
      display:none;
      overflow:hidden;
    }
    .rc-chat.open{ display:flex; flex-direction:column; }
    .rc-chat-header{
      padding: 10px 12px;
      display:flex;
      justify-content:space-between;
      align-items:center;
      border-bottom: 1px solid rgba(255,255,255,.12);
      color: rgba(255,255,255,.92);
    }
    .rc-chat-body{
      padding: 10px 12px;
      flex:1;
      overflow:auto;
      display:flex;
      flex-direction:column;
      gap:10px;
    }
    .rc-msg{
      max-width: 85%;
      padding: 10px 12px;
      border-radius: 14px;
      border: 1px solid rgba(255,255,255,.10);
      white-space: pre-wrap;
      word-break: break-word;
      font-size: 13px;
      line-height: 1.35;
    }
    .rc-msg.user{ align-self:flex-end; background: rgba(255,255,255,.08); }
    .rc-msg.ai{ align-self:flex-start; background: rgba(255,255,255,.04); }
    .rc-chat-footer{
      padding: 10px 12px;
      display:flex;
      gap:10px;
      border-top: 1px solid rgba(255,255,255,.12);
    }
    .rc-chat-footer input{
      flex:1;
      padding: 10px 12px;
      border-radius: 12px;
      border: 1px solid rgba(255,255,255,.14);
      background: rgba(0,0,0,.25);
      color: rgba(255,255,255,.92);
      outline:none;
    }
    .rc-chat-footer button{
      padding: 10px 12px;
      border-radius: 12px;
      border: 1px solid rgba(255,255,255,.14);
      background: rgba(255,255,255,.08);
      color: rgba(255,255,255,.92);
      cursor:pointer;
    }
    .rc-chat-footer button[disabled]{ opacity:.6; cursor:not-allowed; }
  </style>
</head>

<body class="auth-page">
  <header class="nav">
    <div class="container nav-inner">
      <a class="brand" href="/">
        <span class="logo" aria-hidden="true"></span>
        <span>RastreaCom</span>
      </a>

      <div class="nav-links">
        <a href="/user/dashboard">Dashboard</a>
        <a href="/user/analyze">Analizar</a>
      </div>

      <form method="get" action="/auth/logout" style="margin:0;">
        <button class="btn ghost" type="submit">Salir</button>
      </form>
    </div>
  </header>

  <main class="auth-main">
    <section class="hero" style="padding: 34px 0 14px;">
      <div class="parallax" aria-hidden="true">
        <div class="stars" data-speed="0.18"></div>
        <div class="blob one" data-speed="0.35"></div>
        <div class="blob two" data-speed="0.55"></div>
      </div>

      <div class="container">
        <div style="display:flex; align-items:flex-end; justify-content:space-between; gap:14px; flex-wrap:wrap;">
          <div>
            <div class="badge">Analizador</div>
            <h1 style="margin:10px 0 6px; font-size: 26px; letter-spacing: -.3px;">
              Analizar una URL
            </h1>
            <p class="small" style="margin-top:0;">
              Bienvenido,
              <b style="color:rgba(255,255,255,.92)"><%= (user && (user.nombre || user.name || user.email)) || "usuario" %></b>.
              Introduce una web y extrae emails y teléfonos.
            </p>
          </div>

          <div style="display:flex; gap:10px; flex-wrap:wrap;">
            <a class="btn ghost" href="/user/dashboard">← Volver al dashboard</a>
          </div>
        </div>

        <div style="height: 14px;"></div>

        <div class="layout">
          <!-- Panel principal -->
          <div class="card panel">
            <div class="panel-title">
              <strong>Nuevo análisis</strong>
              <span class="badge">POST /user/analyze</span>
            </div>

            <form id="analyzeForm" autocomplete="off" style="display:flex; gap:10px; flex-wrap:wrap;">
              <input
                id="urlInput"
                name="url"
                type="url"
                placeholder="https://..."
                required
                value="<%= (typeof prefillUrl !== 'undefined' && prefillUrl) ? prefillUrl : '' %>"
                style="flex: 1; min-width: 260px;"
              />
              <button id="analyzeBtn" class="btn primary" type="submit">Analizar</button>
            </form>

            <div id="status" class="status">
              <span class="spinner" aria-hidden="true"></span>
              <span class="status-text muted" id="statusText"></span>
            </div>

            <!-- RESULTADO “BONITO” (resumen) -->
            <div id="resultBox" style="display:none; margin-top: 6px;">
              <div class="kv">
                <div class="k">Nombre</div><div class="v" id="name"></div>
                <div class="k">URL</div><div class="v" id="finalUrl"></div>
                <div class="k">Email</div><div class="v" id="bestEmail"></div>
                <div class="k">Teléfono</div><div class="v" id="bestPhone"></div>
              </div>
              <div id="errBox" class="error-box" style="display:none;"></div>
            </div>

            <!-- JSON crudo -->
            <details style="margin-top: 12px;">
              <summary class="small" style="cursor:pointer;">Ver JSON completo</summary>
              <pre id="out" style="margin-top:10px; background: rgba(0,0,0,.18); border:1px solid rgba(255,255,255,.10); border-radius:14px; padding:12px; overflow:auto; color: rgba(255,255,255,.85);"></pre>
            </details>
          </div>

          <!-- Sidebar -->
          <aside class="card panel">
            <div class="panel-title">
              <strong>Últimas analizadas</strong>
              <span class="badge"><%= (recentSites && recentSites.length) ? recentSites.length : 0 %></span>
            </div>

            <% if (!recentSites || recentSites.length === 0) { %>
              <p class="small">Aún no hay sitios guardados. Haz tu primer análisis 🙂</p>
            <% } else { %>
              <div style="display:flex; flex-direction:column; gap:10px;">
                <% recentSites.forEach((s) => { %>
                  <a class="recent-item" href="/user/analyze?url=<%= encodeURIComponent(s.url) %>">
                    <div class="recent-url"><%= s.name ? (s.name + " · ") : "" %><%= s.url %></div>
                    <div class="recent-meta">
                      <span><%= (s.emails ? s.emails.length : 0) %> emails</span>
                      <span><%= (s.phones ? s.phones.length : 0) %> teléfonos</span>
                      <% if (s.error) { %><span style="color: rgba(255,160,160,.9);">error</span><% } %>
                    </div>
                  </a>
                <% }) %>
              </div>

              <p class="small" style="margin-top:10px;">
                Pulsa una URL para precargarla y volver a ver sus datos (cache o fresh).
              </p>
            <% } %>
          </aside>
        </div>
      </div>
    </section>

    <footer class="auth-footer text-center" style="margin-top: 22px;">
      <div class="container footer-inner">
        <span>© <span id="year"></span> RastreaCom</span>
        <span>Analizador · Node + Express · Mongo</span>
      </div>
    </footer>
  </main>

  <!-- Chat widget -->
  <div class="rc-chat" id="rcChat">
    <div class="rc-chat-header">
      <div><b>Asistente</b> <span style="opacity:.7; font-size:12px;">RastreaCom</span></div>
      <div style="display:flex; gap:8px; align-items:center;">
        <button class="btn btn-sm btn-outline-light" id="rcChatClear" type="button">Limpiar</button>
        <button class="btn btn-sm btn-outline-light" id="rcChatClose" type="button">Cerrar</button>
      </div>
    </div>

    <div class="rc-chat-body" id="rcChatBody">
      <div class="rc-msg ai">Hola 👋 ¿En qué te ayudo con RastreaCom?</div>
    </div>

    <div class="rc-chat-footer">
      <input id="rcChatInput" type="text" placeholder="Escribe tu pregunta…" />
      <button id="rcChatSend" type="button">Enviar</button>
    </div>
  </div>

  <div class="rc-chat-launcher" id="rcChatLauncher">💬 <span>Chat</span></div>

  <script>
    (function () {
      // ---- Contexto global para el chatbot ----
      window.__RC_CHAT_CONTEXT__ = {
        page: "analyze",
        lastAnalysis: null
      };

      // ---- Helpers DOM ----
      const $ = (id) => document.getElementById(id);

      // ---- Año footer ----
      $("year").textContent = new Date().getFullYear();

      // ---- UI Analyze ----
      const analyzeForm = $("analyzeForm");
      const analyzeBtn = $("analyzeBtn");
      const out = $("out");
      const status = $("status");
      const statusText = $("statusText");

      const resultBox = $("resultBox");
      const name = $("name");
      const finalUrl = $("finalUrl");
      const bestEmail = $("bestEmail");
      const bestPhone = $("bestPhone");
      const errBox = $("errBox");

      function escapeHtml(str) {
        return String(str)
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#039;");
      }

      function setLoading(isLoading, message = "") {
        status.classList.toggle("loading", isLoading);
        statusText.textContent = message;
        analyzeBtn.disabled = isLoading;
      }

      function pillOrDash(value) {
        const v = (value ?? "").toString().trim();
        return v ? `<span class="pill">${escapeHtml(v)}</span>` : '<span class="muted">—</span>';
      }

      function showResult(payload) {
        const r = payload && payload.result ? payload.result : null;
        if (!r) return;

        resultBox.style.display = "block";

        name.textContent = r.name || "—";
        finalUrl.textContent = r.url || "—";

        const emailMain =
          (r.bestEmail && String(r.bestEmail).trim())
            ? String(r.bestEmail).trim()
            : (Array.isArray(r.emails) && r.emails[0] ? r.emails[0] : "");

        const phoneMain =
          (r.bestPhone && String(r.bestPhone).trim())
            ? String(r.bestPhone).trim()
            : (Array.isArray(r.phones) && r.phones[0] ? r.phones[0] : "");

        bestEmail.innerHTML = pillOrDash(emailMain);
        bestPhone.innerHTML = pillOrDash(phoneMain);

        if (r.error) {
          errBox.style.display = "block";
          errBox.textContent = r.error;
        } else {
          errBox.style.display = "none";
          errBox.textContent = "";
        }
      }

      analyzeForm.addEventListener("submit", async (e) => {
        e.preventDefault();

        const url = new FormData(analyzeForm).get("url");
        out.textContent = "";
        resultBox.style.display = "none";
        errBox.style.display = "none";
        errBox.textContent = "";

        setLoading(true, "Analizando...");

        try {
          const res = await fetch("/user/analyze", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              "Accept": "application/json"
            },
            credentials: "same-origin",
            body: JSON.stringify({ url })
          });

          const data = await res.json().catch(() => ({}));

          if (!res.ok) {
            out.textContent = JSON.stringify(data, null, 2) || "Error al analizar";
            setLoading(false, "Hubo un error.");
            return;
          }

          out.textContent = JSON.stringify(data, null, 2);
          showResult(data);

          // ✅ actualiza contexto del chat con el último análisis
          window.__RC_CHAT_CONTEXT__.lastAnalysis = data;

          setLoading(false, data.source === "cache" ? "Listo ✅ (cache)" : "Listo ✅");
        } catch (err) {
          out.textContent = "Error de red o servidor: " + (err && err.message ? err.message : err);
          setLoading(false, "Error de red.");
        }
      });

      // ---- Parallax ----
      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (!reduceMotion) {
        const layers = document.querySelectorAll("[data-speed]");
        const onScroll = () => {
          const y = window.scrollY || 0;
          layers.forEach(el => {
            const speed = parseFloat(el.getAttribute("data-speed")) || 0.2;
            el.style.transform = `translate3d(0, ${y * speed}px, 0)`;
          });
        };
        onScroll();
        window.addEventListener("scroll", onScroll, { passive: true });
      }

      // ---- Chat widget ----
      const chat = $("rcChat");
      const launcher = $("rcChatLauncher");
      const closeBtn = $("rcChatClose");
      const clearBtn = $("rcChatClear");
      const chatBody = $("rcChatBody");
      const chatInput = $("rcChatInput");
      const chatSend = $("rcChatSend");

      function addMsg(role, text) {
        const div = document.createElement("div");
        div.className = "rc-msg " + (role === "user" ? "user" : "ai");
        div.textContent = text;
        chatBody.appendChild(div);
        chatBody.scrollTop = chatBody.scrollHeight;
      }

      function setChatOpen(open) {
        chat.classList.toggle("open", open);
      }

      launcher.addEventListener("click", () => setChatOpen(!chat.classList.contains("open")));
      closeBtn.addEventListener("click", () => setChatOpen(false));
      clearBtn.addEventListener("click", () => {
        chatBody.innerHTML = '<div class="rc-msg ai">Hola 👋 ¿En qué te ayudo con RastreaCom?</div>';
      });

      async function sendChat() {
        const msg = (chatInput.value || "").trim();
        if (!msg) return;

        addMsg("user", msg);
        chatInput.value = "";
        chatSend.disabled = true;

        const context = window.__RC_CHAT_CONTEXT__ || { page: "analyze", lastAnalysis: null };

        try {
          const res = await fetch("/user/chat", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              "Accept": "application/json"
            },
            credentials: "same-origin",
            body: JSON.stringify({ message: msg, context })
          });

          const data = await res.json().catch(() => ({}));
          if (!res.ok) throw new Error(data.error || "Error en chat");

          addMsg("ai", data.answer || "—");
        } catch (e) {
          addMsg("ai", "⚠️ " + (e && e.message ? e.message : String(e)));
        } finally {
          chatSend.disabled = false;
          chatInput.focus();
        }
      }

      chatSend.addEventListener("click", sendChat);
      chatInput.addEventListener("keydown", (e) => {
        if (e.key === "Enter") sendChat();
      });
    })();
  </script>
</body>
</html>