<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Analizar URL - RastreaCom</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/auth.css">

  <style>
    /* pequeños ajustes específicos de esta pantalla */
    .layout{
      display:grid;
      grid-template-columns: 1fr 360px;
      gap: 14px;
      align-items: start;
    }
    @media (max-width: 980px){
      .layout{ grid-template-columns: 1fr; }
    }
    .status{
      display:flex;
      align-items:center;
      gap:10px;
      min-height:24px;
      margin-top: 8px;
    }
    .spinner{
      width:18px; height:18px;
      border:3px solid rgba(255,255,255,.18);
      border-top-color: rgba(255,255,255,.75);
      border-radius:50%;
      animation: spin .8s linear infinite;
      display:none;
    }
    .loading .spinner{ display:inline-block; }
    .loading .status-text{ opacity:.85; }
    @keyframes spin{ to { transform: rotate(360deg); } }

    /* salida bonita */
    .kv{
      display:grid;
      grid-template-columns: 130px 1fr;
      gap: 8px 12px;
      margin-top: 10px;
    }
    .kv .k{ color: rgba(255,255,255,.68); font-size: 12px; }
    .kv .v{ color: rgba(255,255,255,.92); font-size: 13px; word-break: break-word; }
    .pill{
      display:inline-flex;
      align-items:center;
      padding: 6px 10px;
      border-radius: 999px;
      border: 1px solid rgba(255,255,255,.12);
      background: rgba(255,255,255,.05);
      color: rgba(255,255,255,.85);
      font-size: 12px;
      margin: 4px 6px 0 0;
      text-decoration: none;
    }
    .pill:hover{ background: rgba(255,255,255,.07); }

    .muted{ color: rgba(255,255,255,.68); }

    /* lista recientes */
    .recent-item{
      display:flex;
      flex-direction: column;
      gap: 2px;
      padding: 10px 10px;
      border-radius: 14px;
      border: 1px solid rgba(255,255,255,.10);
      background: rgba(255,255,255,.04);
      text-decoration: none;
    }
    .recent-item:hover{ background: rgba(255,255,255,.06); border-color: rgba(255,255,255,.16); }
    .recent-url{
      color: rgba(255,255,255,.92);
      font-size: 13px;
      word-break: break-word;
    }
    .recent-meta{
      font-size: 12px;
      color: rgba(255,255,255,.62);
      display:flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    /* panel de error */
    .error-box{
      border: 1px solid rgba(255,120,120,.25);
      background: rgba(255,80,80,.08);
      color: rgba(255,220,220,.95);
      padding: 10px 12px;
      border-radius: 14px;
      font-size: 13px;
      margin-top: 10px;
      white-space: pre-wrap;
    }
  </style>
</head>

<body class="auth-page">
  <header class="nav">
    <div class="container nav-inner">
      <a class="brand" href="/">
        <span class="logo" aria-hidden="true"></span>
        <span>RastreaCom</span>
      </a>

      <div class="nav-links">
        <a href="/user/dashboard">Dashboard</a>
        <a href="/user/analyze">Analizar</a>

      </div>

      <form method="POST" action="/logout" style="margin:0;">
        <button class="btn ghost" type="submit">Salir</button>
      </form>
    </div>
  </header>

  <main class="auth-main">
    <section class="hero" style="padding: 34px 0 14px;">
      <div class="parallax" aria-hidden="true">
        <div class="stars" data-speed="0.18"></div>
        <div class="blob one" data-speed="0.35"></div>
        <div class="blob two" data-speed="0.55"></div>
      </div>

      <div class="container">
        <div style="display:flex; align-items:flex-end; justify-content:space-between; gap:14px; flex-wrap:wrap;">
          <div>
            <div class="badge">Analizador</div>
            <h1 style="margin:10px 0 6px; font-size: 26px; letter-spacing: -.3px;">
              Analizar una URL
            </h1>
            <p class="small" style="margin-top:0;">
              Bienvenido, <b style="color:rgba(255,255,255,.92)"><%= (user && (user.nombre || user.name || user.email)) || "usuario" %></b>.
              Introduce una web y extrae emails y teléfonos.
            </p>
          </div>

          <div style="display:flex; gap:10px; flex-wrap:wrap;">
            <a class="btn ghost" href="/user/dashboard">← Volver al dashboard</a>
          </div>
        </div>

        <div style="height: 14px;"></div>

        <div class="layout">
          <!-- PANEL PRINCIPAL -->
          <div class="card panel">
            <div class="panel-title">
              <strong>Nuevo análisis</strong>
              <span class="badge">POST /user/analyze</span>
            </div>

            <form id="f" autocomplete="off" style="display:flex; gap:10px; flex-wrap:wrap;">
              <input
                id="url"
                name="url"
                type="url"
                placeholder="https://..."
                required
                value="<%= (typeof prefillUrl !== 'undefined' && prefillUrl) ? prefillUrl : '' %>"
                style="flex: 1; min-width: 260px;"
              />
              <button id="btn" class="btn primary" type="submit">Analizar</button>
            </form>

            <div id="status" class="status">
              <span class="spinner" aria-hidden="true"></span>
              <span class="status-text muted" id="statusText"></span>
            </div>

            <!-- RESULTADO “BONITO” -->
            <div id="resultBox" style="display:none; margin-top: 6px;">
              <div class="kv">
                <div class="k">Fuente</div><div class="v" id="src"></div>
                <div class="k">Nombre</div><div class="v" id="name"></div>
                <div class="k">URL</div><div class="v" id="finalUrl"></div>
                <div class="k">Emails</div><div class="v" id="emails"></div>
                <div class="k">Teléfonos</div><div class="v" id="phones"></div>
                <div class="k">Visitadas</div><div class="v" id="visited"></div>
              </div>
              <div id="errBox" class="error-box" style="display:none;"></div>
            </div>

            <!-- JSON crudo (por si quieres) -->
            <details style="margin-top: 12px;">
              <summary class="small" style="cursor:pointer;">Ver JSON completo</summary>
              <pre id="out" style="margin-top:10px; background: rgba(0,0,0,.18); border:1px solid rgba(255,255,255,.10); border-radius:14px; padding:12px; overflow:auto; color: rgba(255,255,255,.85);"></pre>
            </details>
          </div>

          <!-- SIDEBAR ÚLTIMAS ANALIZADAS -->
          <aside class="card panel">
            <div class="panel-title">
              <strong>Últimas analizadas</strong>
              <span class="badge"><%= (recentSites && recentSites.length) ? recentSites.length : 0 %></span>
            </div>

            <% if (!recentSites || recentSites.length === 0) { %>
              <p class="small">Aún no hay sitios guardados. Haz tu primer análisis 🙂</p>
            <% } else { %>
              <div style="display:flex; flex-direction:column; gap:10px;">
                <% recentSites.forEach((s) => { %>
                  <a class="recent-item" href="/user/analyze?url=<%= encodeURIComponent(s.url) %>">
                    <div class="recent-url"><%= s.name ? (s.name + " · ") : "" %><%= s.url %></div>
                    <div class="recent-meta">
                      <span><%= (s.emails ? s.emails.length : 0) %> emails</span>
                      <span><%= (s.phones ? s.phones.length : 0) %> teléfonos</span>
                      <% if (s.error) { %><span style="color: rgba(255,160,160,.9);">error</span><% } %>
                    </div>
                  </a>
                <% }) %>
              </div>

              <p class="small" style="margin-top:10px;">
                Pulsa una URL para precargarla y volver a ver sus datos (cache o fresh).
              </p>
            <% } %>
          </aside>
        </div>
      </div>
    </section>

    <footer class="auth-footer text-center" style="margin-top: 22px;">
      <div class="container footer-inner">
        <span>© <span id="year"></span> RastreaCom</span>
        <span>Analizador · Node + Express · Mongo</span>
      </div>
    </footer>
  </main>

  <script>
    document.getElementById("year").textContent = new Date().getFullYear();

    const f = document.getElementById("f");
    const out = document.getElementById("out");
    const status = document.getElementById("status");
    const statusText = document.getElementById("statusText");
    const btn = document.getElementById("btn");

    const resultBox = document.getElementById("resultBox");
    const src = document.getElementById("src");
    const name = document.getElementById("name");
    const finalUrl = document.getElementById("finalUrl");
    const emails = document.getElementById("emails");
    const phones = document.getElementById("phones");
    const visited = document.getElementById("visited");
    const errBox = document.getElementById("errBox");

    function setLoading(isLoading, message = "") {
      status.classList.toggle("loading", isLoading);
      statusText.textContent = message;
      btn.disabled = isLoading;
    }

    function renderPills(list) {
      if (!Array.isArray(list) || list.length === 0) return '<span class="muted">—</span>';
      return list.map(v => `<span class="pill">${escapeHtml(v)}</span>`).join("");
    }

    function escapeHtml(str){
      return String(str)
        .replaceAll("&","&amp;")
        .replaceAll("<","&lt;")
        .replaceAll(">","&gt;")
        .replaceAll('"',"&quot;")
        .replaceAll("'","&#039;");
    }

    function showResult(payload){
      const result = payload && payload.result ? payload.result : null;
      if (!result) return;

      resultBox.style.display = "block";
      src.textContent = payload.source || "—";
      name.textContent = result.name || "—";
      finalUrl.textContent = result.url || "—";

      emails.innerHTML = renderPills(result.emails);
      phones.innerHTML = renderPills(result.phones);
      visited.innerHTML = renderPills(result.visited);

      if (result.error) {
        errBox.style.display = "block";
        errBox.textContent = result.error;
      } else {
        errBox.style.display = "none";
        errBox.textContent = "";
      }
    }

    f.addEventListener("submit", async (e) => {
      e.preventDefault();

      const url = new FormData(f).get("url");
      out.textContent = "";
      resultBox.style.display = "none";
      errBox.style.display = "none";
      errBox.textContent = "";

      setLoading(true, "Analizando...");

      try {
        const r = await fetch("/user/analyze", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ url })
        });

        const data = await r.json().catch(() => ({}));

        if (!r.ok) {
          out.textContent = JSON.stringify(data, null, 2) || "Error al analizar";
          setLoading(false, "Hubo un error.");
          return;
        }

        out.textContent = JSON.stringify(data, null, 2);
        showResult(data);
        setLoading(false, data.source === "cache" ? "Listo ✅ (cache)" : "Listo ✅");
      } catch (err) {
        out.textContent = "Error de red o servidor: " + (err && err.message ? err.message : err);
        setLoading(false, "Error de red.");
      }
    });

    // Parallax suave
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (!reduceMotion) {
      const layers = document.querySelectorAll("[data-speed]");
      const onScroll = () => {
        const y = window.scrollY || 0;
        layers.forEach(el => {
          const speed = parseFloat(el.getAttribute("data-speed")) || 0.2;
          el.style.transform = `translate3d(0, ${y * speed}px, 0)`;
        });
      };
      onScroll();
      window.addEventListener("scroll", onScroll, { passive: true });
    }
  </script>
</body>
</html>