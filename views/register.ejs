<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <title>Registro - RastreaCom</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="styles.css">
</head>

<body class="bg-light">
    <header>
        <nav class="navbar navbar-light bg-light">
            <div class="container">
                <a class="navbar-brand" href="index.html">RastreaCom</a>
            </div>
        </nav>
    </header>
    <main class="flex-grow-1">

        <div class="container mt-5">
            <div class="card mx-auto shadow" style="max-width:400px;">
                <div class="card-body">
                    <h3 class="text-success mb-3">Registro</h3>

                    <div id="registerMessage" class="mb-3 text-center"></div>
                    <form id="registerForm" method="POST" action="">
                        <div class="mb-3">
                            <input type="text" name="nombre" class="form-control" placeholder="Nombre completo" required>
                        </div>
                        <div class="mb-3">
                            <input type="email" name="email" class="form-control" placeholder="Email" required>
                        </div>
                        <div class="mb-3">
                            <input type="password" name="password" class="form-control" placeholder="Password" required>
                        </div>
                        <div class="mb-3">
                            <input type="password" name="password2" class="form-control" placeholder="Confirmar Password"
                                required>
                        </div>
                        <div class="mb-3">
                            <input type="number" name="edad" class="form-control" placeholder="Edad" min="18" required>
                        </div>
                        <button class="btn btn-success w-100" type="submit">Registrarse</button>
                    </form>

                    <p class="mt-3 text-center">
                        <a href="login.html">Ya tengo cuenta</a>
                    </p>

                </div>
            </div>
        </div>


    </main>

    <footer class="text-center py-3 mt-4" style="background:#ffc0cb;">
        <div class="container">
            <small>&copy; 2026 RastreaCom. Todos los derechos reservados.</small>
        </div>
    </footer>

</body>

</html>