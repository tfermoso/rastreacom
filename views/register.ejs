<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>Registro - RastreaFormacom</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/auth.css">
</head>

<body class="auth-page">
    <header class="nav">
        <div class="container nav-inner">
            <a class="brand" href="/">
                <span class="logo" aria-hidden="true"></span>
                <span>RastreaCom</span>
            </a>

          

            <a class="btn primary" href="login">Acceder →</a>
        </div>
    </header>

    <main class="auth-main">
        <div class="auth-container">
            <div class="card auth-card mx-auto" style="max-width: 460px;">
                <div class="card-body p-4">
                    <h3 class="auth-title">Crear cuenta</h3>
                    <p class="auth-sub">Regístrate para acceder al panel y comenzar a analizar URLs.</p>

                    <div id="registerMessage" class="mb-3 text-center"></div>

                    <form id="registerForm" method="POST" action="">
                        <div class="mb-3">
                            <input type="text" name="nombre" class="form-control auth-input"
                                placeholder="Nombre completo" required>
                        </div>

                        <div class="mb-3">
                            <input type="email" name="email" class="form-control auth-input" placeholder="Email"
                                required>
                        </div>

                        <div class="mb-3">
                            <input type="password" name="password" class="form-control auth-input"
                                placeholder="Password" required>
                        </div>

                        <div class="mb-3">
                            <input type="password" name="password2" class="form-control auth-input"
                                placeholder="Confirmar password" required>
                        </div>

                        <div class="mb-3">
                            <input type="number" name="edad" class="form-control auth-input" placeholder="Edad" min="18"
                                required>
                        </div>

                        <button class="btn w-100 auth-btn" type="submit">Registrarse</button>
                    </form>

                    <p class="mt-3 text-center">
                        <a class="auth-link" href="/auth/login">Ya tengo cuenta</a>
                    </p>
                </div>
            </div>
        </div>
    </main>

    <footer class="auth-footer text-center">
        <div class="auth-container">
            <small>&copy; 2026 RastreaFormacom. Todos los derechos reservados.</small>
        </div>
    </footer>
</body>

</html>